rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Esta versão usa login interno no app + Firebase Auth anônimo para impedir acesso totalmente público.
    // As permissões de perfil continuam sendo aplicadas pela interface do sistema.
    // Para proteção corporativa completa por perfil no Firestore, é necessário Cloud Functions/custom claims.
    match /usuarios/{userId} {
      allow read, write: if signedIn();
    }

    match /alunos/{docId} {
      allow read, write: if signedIn();
    }

    match /ocorrencias/{docId} {
      allow read, write: if signedIn();
    }

    match /configuracoes/{docId} {
      allow read, write: if signedIn();
    }

    match /importacoes/{docId} {
      allow read, write: if signedIn();
    }

    match /auditoria/{docId} {
      allow read, write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
