rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)); }
    function isAdmin() { return signedIn() && userDoc().data.role == 'admin'; }

    match /usuarios/{uid} {
      allow read: if signedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() || request.auth.uid == uid;
    }

    match /alunos/{id} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /ocorrencias/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
