rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /*
      ATENÇÃO:
      Esta versão usa login interno por usuário/senha no próprio sistema,
      sem Firebase Authentication.
      Por limitação do Firestore Rules, o banco precisa aceitar leitura/escrita
      do app público hospedado no GitHub Pages.

      A segurança de perfis é aplicada pela interface do sistema.
      Não publique planilhas/dados sensíveis no GitHub.
      Para proteção real no banco, use Firebase Authentication, App Check
      ou backend/Cloud Functions.
    */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
